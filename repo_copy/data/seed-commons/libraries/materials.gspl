// -----------------------------------------------------------------------------
// 4. Laws
// -----------------------------------------------------------------------------

pub fn hookes_stress(strain: Scalar, youngs_modulus_gpa: Scalar) -> Scalar pure =
    strain * youngs_modulus_gpa * 1e9

pub fn fresnel_reflectance_normal(n1: Scalar, n2: Scalar) -> Scalar pure =
    let r = (n1 - n2) / (n1 + n2)
    r * r

// -----------------------------------------------------------------------------
// 5. Functors
// -----------------------------------------------------------------------------

pub fn material_to_pbr_shader_functor() -> Functor pure =
    Functor.id("materials://functor/material_to_pbr_shader@v1")

pub fn material_to_acoustic_impulse_functor() -> Functor pure =
    Functor.id("materials://functor/material_to_acoustic_impulse@v1")

