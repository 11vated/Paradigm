// seed-commons/libraries/materials.gspl
//
// Materials library — runnable GSPL materialization of Brief 083
// (research/083-materials-library.md).
//
// PURE. Sources: MatWeb, NIST, ASM Handbook, ASTM, ISO, Granta, ICSD.
// Every material primitive composes through the Material struct and carries
// optical, thermal, mechanical, acoustic, and PBR render properties.
//
// Kernel mapping:
//   scalar      -> density, Young's modulus, thermal conductivity
//   categorical -> crystal system, material class, phase
//   vector      -> anisotropic stiffness tensor rows, reflectance spectrum
//   struct      -> Material record (full PBR + physical + acoustic)
//   field       -> stress, strain, temperature field
//   resonance   -> sound speed, acoustic absorption, modal frequencies
//   symbolic    -> MatWeb ID, ASTM designation, chemical formula
//   dimensional -> CLIP appearance embedding
//   sovereignty -> signed provenance
//
// rng_seed = "seed_commons.libraries.materials:v1"
// License: GSPL Open Specification License
// Lineage parents: [seed_commons.libraries.chemistry@v1, seed_commons.libraries.physics@v1]

module seed_commons.libraries.materials

import Std.Math
import Std.Color
import Std.Units
import seed_commons.libraries.chemistry as Chem
import seed_commons.libraries.physics as Phys

// -----------------------------------------------------------------------------
// 1. Material class taxonomy
// -----------------------------------------------------------------------------

pub enum MaterialClass {
    Metal, Alloy, Ceramic, Glass, Polymer, Elastomer, Composite,
    Wood, Stone, Mineral, Concrete, Textile, Paper, Leather,
    BiologicalTissue, IceOrSnow, Foam, Liquid, GasMedium, Exotic,
}

pub enum CrystalSystem {
    Cubic, Tetragonal, Orthorhombic, Hexagonal, Trigonal, Monoclinic, Triclinic, Amorphous,
}

// -----------------------------------------------------------------------------
// 2. Material struct
// -----------------------------------------------------------------------------

pub struct Material {
    name: String,
    class: MaterialClass,
    crystal: CrystalSystem,
    // Physical
    density_kg_m3: Scalar,
    molar_mass_g_mol: Option<Scalar>,
    melt_point_k: Option<Scalar>,
    // Mechanical
    youngs_modulus_gpa: Scalar,
    shear_modulus_gpa: Scalar,
    poisson_ratio: Scalar,
    yield_strength_mpa: Option<Scalar>,
    hardness_mohs: Option<Scalar>,
    // Thermal
    thermal_conductivity_w_mk: Scalar,
    specific_heat_j_kgk: Scalar,
    thermal_expansion_1_k: Scalar,
    // Electrical
    resistivity_ohm_m: Option<Scalar>,
    relative_permittivity: Option<Scalar>,
    // Optical (PBR)
    base_color_srgb: Std.Color.sRGB,
    ior_real: Scalar,
    ior_imag: Scalar,
    roughness: Scalar,
    metallic: Scalar,
    subsurface_mm: Scalar,
    anisotropy: Scalar,
    // Acoustic
    sound_speed_m_s: Scalar,
    acoustic_impedance_mrayl: Scalar,
}

// -----------------------------------------------------------------------------
// 3. Core inventory — load-bearing for downstream inventory seeds
// -----------------------------------------------------------------------------

