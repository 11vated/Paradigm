        absorption_nm = Vector.from_spectrum(400.0, 700.0, 60),
        cie_color = Std.Color.OKLCh { l = 0.38, c = 0.16, h = 265.0 },
        lightfastness = 8.0,
        opacity = 0.7,
        vehicle = "oil",
        period_start = 1828.0,
        citation = "coa:PB29@v2023",
    }

