    Molecule.diatomic(element = oxygen(), bond_order = 2.0, name = "dioxygen", cid = 977.0)

pub fn iron_metal() -> Molecule pure =
    Molecule.pure_metal(element = iron(), phase = "solid", crystal = "BCC")

pub fn iron_iii_oxide_hydrated() -> Molecule pure =
    Molecule.from_formula("Fe2O3·xH2O", common_name = "rust", cid = 518696.0)

pub fn glucose() -> Molecule pure =
    Molecule.from_pubchem(cid = 5793.0, common_name = "glucose")

