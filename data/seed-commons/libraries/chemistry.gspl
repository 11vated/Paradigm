// seed-commons/libraries/chemistry.gspl
//
// Chemistry substrate library — the runnable GSPL materialization of Brief 081
// (research/081-chemistry-primitives-library.md).
//
// This module is PURE. No Network, no Time, no wall clock. Every value is
// grounded in NIST, IUPAC, CODATA, PubChem, KEGG, HITRAN, or US Standard
// Atmosphere 1976. Every primitive declared here is addressable by downstream
// seeds as `Chemistry.<primitive>` and composes cleanly with the 17 kernel
// gene types from spec/02-gene-system.md.
//
// The library does not ship the full 50,000-molecule / 5,000-reaction v1
// catalog inline — those live under seed-commons/libraries/chemistry/data/
// as signed content-addressed fragments loaded on demand. What this file
// ships is:
//
//   1. The TYPES every chemistry primitive is expressed in.
//   2. The CANONICAL CONSTANTS (CODATA 2022) the substrate treats as ground truth.
//   3. A curated CORE INVENTORY of the primitives that every downstream seed
//      in the commons is allowed to depend on without a data-fetch round trip.
//   4. The FUNCTORS that cross chemistry into other engines (light, material,
//      particle, fluid, biology) per Briefs 083, 084, 085.
//
// Every primitive below is load-bearing for a seed in seed-commons/inventories/.
// Removing any one of them breaks a downstream canonical seed.
//
// Determinism: rng_seed = "seed_commons.libraries.chemistry:v1"
// License: GSPL Open Specification License
// Lineage parents: [] (primordial library; consumes no other commons module)

module seed_commons.libraries.chemistry

import Std.Math
import Std.Color
import Std.Units
import Std.Embedding

// -----------------------------------------------------------------------------
// 1. Kernel-gene mappings
// -----------------------------------------------------------------------------
// Every chemistry primitive below is declared in terms of the 17 kernel gene
// types from spec/02. The mapping is explicit so a reader can trace any
// chemistry value back to the kernel algebra without guessing.
//
//   scalar      -> masses, temperatures, rate constants, energies, pH
//   categorical -> element symbol, phase, crystal system, oxidation state
//   vector      -> emission spectrum bins, dipole moment, crystal lattice vectors
//   expression  -> rate law, Arrhenius law, partition function
//   struct      -> element, molecule, reaction, pathway, pigment records
//   array       -> isotope list, conformer ensemble, reaction step list
//   graph       -> molecular bond graph, reaction network, metabolic pathway
//   topology    -> 3D conformer surfaces, active-site pockets
//   temporal    -> reaction progress, decay curves, fluorescence lifetimes
//   regulatory  -> enzyme kinetics, allosteric networks, pH buffering
//   field       -> electron density, electrostatic potential, ion concentration
//   symbolic    -> IUPAC name, SMILES, InChI, CAS number
//   quantum     -> HOMO/LUMO superposition, orbital hybridization states
//   gematria    -> — (not used by chemistry)
//   resonance   -> vibrational IR modes, NMR shifts, Raman spectra
//   dimensional -> CLIP-style embeddings of molecule / material appearance
//   sovereignty -> signed identity of every primitive in this library
// -----------------------------------------------------------------------------

// -----------------------------------------------------------------------------
// 2. Canonical constants (CODATA 2022)
// -----------------------------------------------------------------------------
// These are exact substrate-level constants. Every downstream seed that needs
// a physical constant MUST reference one of these, never inline a literal.

pub const AVOGADRO        : Scalar = 6.022_140_76e23        // 1/mol, exact
pub const BOLTZMANN_K     : Scalar = 1.380_649e-23          // J/K,  exact
pub const GAS_R           : Scalar = 8.314_462_618_153_24   // J/(mol K), exact
pub const FARADAY         : Scalar = 96_485.332_123_310_0   // C/mol
pub const PLANCK_H        : Scalar = 6.626_070_15e-34       // J s, exact
pub const SPEED_OF_LIGHT  : Scalar = 299_792_458.0          // m/s, exact
pub const ELEMENTARY_Q    : Scalar = 1.602_176_634e-19      // C, exact
pub const ELECTRON_MASS   : Scalar = 9.109_383_713_9e-31    // kg
pub const PROTON_MASS     : Scalar = 1.672_621_925_95e-27   // kg
pub const AMU             : Scalar = 1.660_539_068_92e-27   // kg (unified atomic mass unit)
pub const STANDARD_T      : Scalar = 298.15                 // K, thermodynamic standard
pub const STANDARD_P      : Scalar = 101_325.0              // Pa, 1 atm
pub const WATER_TRIPLE_T  : Scalar = 273.16                 // K, exact by definition

// -----------------------------------------------------------------------------
// 3. Core type algebra
// -----------------------------------------------------------------------------

// An element record. Fields traced to NIST / IUPAC 2021.
pub type Element = struct {
    symbol           : Categorical,        // "H", "He", "Fe", ...
    atomic_number    : Scalar,             // integer-valued
    standard_weight  : Scalar,             // g/mol, IUPAC 2021
    group            : Scalar,             // 1..18
    period           : Scalar,             // 1..7
    block            : Categorical,        // s | p | d | f
    electron_config  : Symbolic,           // e.g. "[Ar] 3d6 4s2"
    electronegativity_pauling : Scalar,    // dimensionless
    ionization_energy_1 : Scalar,          // kJ/mol
    electron_affinity : Scalar,            // kJ/mol
    atomic_radius_pm : Scalar,             // pm (Slater)
    covalent_radius_pm : Scalar,           // pm
    density_kg_m3    : Scalar,             // at STP
    melting_K        : Scalar,
    boiling_K        : Scalar,
    heat_capacity    : Scalar,             // J/(mol K) at STP
    thermal_conductivity : Scalar,         // W/(m K)
    common_oxidation_states : Array<Scalar>,
    flame_color      : Std.Color.OKLCh,    // OKLab flame test color
    crystal_structure : Categorical,       // BCC | FCC | HCP | ...
    emission_lines_nm : Vector,            // NIST ASD primary lines
    citation         : Symbolic,           // DOI or NIST pointer
    uncertainty      : Scalar,             // [0,1], aggregate provenance confidence
}

// A molecule record. Consistent with PubChem CID schema.
pub type Molecule = struct {
    pubchem_cid      : Scalar,             // integer-valued; 0 if not in PubChem
    inchi_key        : Symbolic,
    smiles           : Symbolic,
    iupac_name       : Symbolic,
    common_name      : Symbolic,
    cas_number       : Symbolic,
    formula          : Symbolic,
    molecular_weight : Scalar,             // g/mol
    exact_mass       : Scalar,             // g/mol, monoisotopic
    charge           : Scalar,
    spin_multiplicity : Scalar,
    bond_graph       : Graph<Atom, Bond>,  // kernel graph gene
    conformers       : Topology,           // kernel topology gene
    dipole_moment    : Vector,             // D, Debye
    homo_ev          : Scalar,
    lumo_ev          : Scalar,
    logp             : Scalar,
    pka              : Array<Scalar>,
    uv_vis_nm        : Vector,             // absorption bins
    ir_vibrational   : Resonance,          // kernel resonance gene
    nmr_shifts       : Array<Scalar>,      // ppm
    appearance_color : Std.Color.OKLCh,
    ghs_hazard       : Array<Categorical>,
    embedding        : Dimensional,        // Std.Embedding.clip_v1
    citation         : Symbolic,
}

pub type Atom = struct {
    element    : Categorical,
    position   : Vector,                   // Å, 3D
    charge     : Scalar,
    isotope    : Scalar,                   // mass number; 0 = natural abundance
}

pub type Bond = struct {
    order      : Scalar,                   // 1, 1.5, 2, 3
    kind       : Categorical,              // single | aromatic | double | triple | coordinate
    stereo     : Categorical,              // none | E | Z | R | S
}

// A reaction record with full kinetics and thermodynamics.
pub type Reaction = struct {
    name             : Symbolic,
    reactants        : Array<Molecule>,
    products         : Array<Molecule>,
    stoichiometry    : Array<Scalar>,
    conditions       : struct {
        temperature_K : Scalar,
        pressure_pa   : Scalar,
        catalyst      : Symbolic,
        solvent       : Symbolic,
        light_required : Categorical,     // none | uv | visible | ir
    },
    rate_law         : Expression,         // kernel expression gene
    arrhenius_a      : Scalar,
    activation_kj    : Scalar,             // Ea, kJ/mol
    delta_h          : Scalar,             // kJ/mol
    delta_s          : Scalar,             // J/(mol K)
    delta_g          : Scalar,             // kJ/mol at STANDARD_T
    equilibrium_k    : Scalar,
    mechanism        : Array<Reaction>,    // elementary steps
    hazards          : Array<Categorical>,
    citation         : Symbolic,
}

// A metabolic pathway as a graph of reactions.
pub type Pathway = struct {
    kegg_id          : Symbolic,
    name             : Symbolic,
    reaction_graph   : Graph<Reaction, PathwayEdge>,
    enzymes          : Array<EnzymeEC>,
    regulatory_net   : Regulatory,         // kernel regulatory gene
    citation         : Symbolic,
}

pub type PathwayEdge = struct {
    flux_direction   : Categorical,        // forward | reverse | reversible
    cofactor         : Symbolic,
}

pub type EnzymeEC = struct {
    ec_number        : Symbolic,           // "1.1.1.1" style
    name             : Symbolic,
    km               : Scalar,             // Michaelis-Menten, mol/L
    kcat             : Scalar,             // 1/s
    optimum_ph       : Scalar,
    optimum_T_K      : Scalar,
}

// A pigment record for photochemistry and substrate-level color grounding.
pub type Pigment = struct {
    color_index      : Symbolic,           // "PB29" (ultramarine), "PY43" (yellow ochre)
    common_name      : Symbolic,
    chemical_formula : Symbolic,
    absorption_nm    : Vector,             // measured absorption spectrum
    cie_color        : Std.Color.OKLCh,    // computed from absorption under D65
    lightfastness    : Scalar,             // Blue Wool scale 1..8
    opacity          : Scalar,             // [0,1]
    vehicle          : Categorical,        // oil | watercolor | acrylic | tempera | fresco
    period_start     : Scalar,             // historical first use, year
    citation         : Symbolic,
}

// A fluorophore record.
pub type Fluorophore = struct {
    name             : Symbolic,
    excitation_nm    : Scalar,
    emission_nm      : Scalar,
    quantum_yield    : Scalar,             // [0,1]
    extinction       : Scalar,             // M^-1 cm^-1
    lifetime_ns      : Temporal,           // kernel temporal gene
    citation         : Symbolic,
}

// A force field family for differentiable simulation (Brief 071).
pub type ForceField = struct {
    family           : Categorical,        // GAFF | OPLS | AMBER | CHARMM | MMFF94 | ReaxFF | Tersoff | EAM
    version          : Symbolic,
    parameter_graph  : Graph<Atom, ForceFieldTerm>,
    license          : Symbolic,
    citation         : Symbolic,
}

pub type ForceFieldTerm = struct {
    kind             : Categorical,        // bond | angle | dihedral | lj | coulomb
    parameters       : Array<Scalar>,
}

// Atmospheric reference state (US Standard Atmosphere 1976).
pub type Atmosphere = struct {
    altitude_m       : Scalar,
    temperature_K    : Scalar,
    pressure_pa      : Scalar,
    density_kg_m3    : Scalar,
    composition      : Array<struct { species : Symbolic, mole_fraction : Scalar }>,
    hitran_profile   : Field,              // kernel field gene: absorption vs wavelength
    citation         : Symbolic,
}

