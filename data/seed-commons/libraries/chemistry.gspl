// -----------------------------------------------------------------------------
// 5. Canonical reactions
// -----------------------------------------------------------------------------

// Methane combustion — the reference seed for every candle, stove, and torch.
pub fn combust_methane() -> Reaction pure =
    Reaction {
        name = "combustion.methane",
        reactants = [methane(), oxygen_gas()],
        products  = [carbon_dioxide(), water()],
        stoichiometry = [1.0, 2.0, 1.0, 2.0],
        conditions = {
            temperature_K = 1950.0,        // adiabatic flame T in air
            pressure_pa = STANDARD_P,
            catalyst = "",
            solvent = "",
            light_required = "none",
        },
        rate_law = Expression.arrhenius(
            a = 1.3e8,                     // from NIST Kinetics Database
            ea = 202.5,                    // kJ/mol
            orders = [0.7, 0.8],
        ),
        arrhenius_a = 1.3e8,
        activation_kj = 202.5,
        delta_h = -890.36,                 // kJ/mol, exothermic
        delta_s = -242.8,
        delta_g = -818.0,
        equilibrium_k = 1.0e143,
        mechanism = [],                    // elementary steps omitted here; loaded from chemistry/data/
        hazards = ["explosive_at_5_to_15_percent_v_v"],
        citation = "nist-kinetics:combust-ch4@v2022",
    }

// Iron oxidation — rust formation reference for every "ruined sword" seed.
pub fn rust_iron() -> Reaction pure =
    Reaction {
        name = "oxidation.iron.aqueous",
        reactants = [iron_metal(), oxygen_gas(), water()],
        products  = [iron_iii_oxide_hydrated()],
        stoichiometry = [4.0, 3.0, 6.0, 2.0],
        conditions = {
            temperature_K = 298.15,
            pressure_pa = STANDARD_P,
            catalyst = "NaCl(aq)",        // salt accelerator
            solvent = "water",
            light_required = "none",
        },
        rate_law = Expression.empirical_rust(
            k = 2.5e-5,
            ea = 42.0,
        ),
        arrhenius_a = 5.0e6,
        activation_kj = 42.0,
        delta_h = -823.4,
        delta_s = -543.7,
        delta_g = -742.2,
        equilibrium_k = 1.0e130,
        mechanism = [],
        hazards = [],
        citation = "kegg:R02061@v2024",
    }

// Photosynthesis — canonical biochemical reference for plant seeds.
pub fn photosynthesis() -> Reaction pure =
    Reaction {
        name = "biochemistry.photosynthesis.net",
        reactants = [carbon_dioxide(), water()],
        products  = [glucose(), oxygen_gas()],
        stoichiometry = [6.0, 6.0, 1.0, 6.0],
        conditions = {
            temperature_K = 298.15,
            pressure_pa = STANDARD_P,
            catalyst = "rubisco",
            solvent = "water",
            light_required = "visible",
        },
        rate_law = Expression.light_dependent(
            phi = 0.08,                    // quantum yield
            saturation_par = 1800.0,       // μmol photons / m^2 s
        ),
        arrhenius_a = 0.0,                 // light-driven, not thermal
        activation_kj = 2870.0,            // net photon energy requirement
        delta_h = 2803.0,                  // endothermic; photon-driven
        delta_s = -210.0,
        delta_g = 2870.0,
        equilibrium_k = 0.0,
        mechanism = [],
        hazards = [],
        citation = "kegg:R00024@v2024",
    }

// -----------------------------------------------------------------------------
// 6. Canonical pigments (grounded in Color of Art pigment DB)
// -----------------------------------------------------------------------------

pub fn ultramarine_blue() -> Pigment pure =
    Pigment {
        color_index = "PB29",
