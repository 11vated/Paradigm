    Atmosphere {
        altitude_m = 0.0,
        temperature_K = 288.15,
        pressure_pa = 101_325.0,
        density_kg_m3 = 1.225,
        composition = [
            { species = "N2",  mole_fraction = 0.78084  },
            { species = "O2",  mole_fraction = 0.20946  },
            { species = "Ar",  mole_fraction = 0.00934  },
            { species = "CO2", mole_fraction = 0.000421 },
            { species = "Ne",  mole_fraction = 0.0000182},
            { species = "He",  mole_fraction = 0.00000524},
            { species = "CH4", mole_fraction = 0.00000192},
        ],
        hitran_profile = Field.from_hitran("standard-sea-level@v2020"),
        citation = "nasa:us-standard-atmosphere-1976",
    }

// -----------------------------------------------------------------------------
// 8. Cross-domain functors — the real leverage
// -----------------------------------------------------------------------------
// These are the functions downstream seeds compose to turn chemistry into
// renderable substrate. Every functor is pure. Every functor is deterministic.

// Convert a pigment's absorption spectrum into a paintable Std.Color.Palette.
pub fn functor_pigment_to_palette(p : Pigment) -> Std.Color.Palette pure =
    Std.Color.Palette.from_oklch([
        Std.Color.OKLCh { l = p.cie_color.l * 0.35, c = p.cie_color.c * 0.70, h = p.cie_color.h },
        Std.Color.OKLCh { l = p.cie_color.l * 0.75, c = p.cie_color.c * 0.95, h = p.cie_color.h },
        Std.Color.OKLCh { l = p.cie_color.l,         c = p.cie_color.c,         h = p.cie_color.h },
        Std.Color.OKLCh { l = min(0.98, p.cie_color.l * 1.18), c = p.cie_color.c * 0.60, h = p.cie_color.h },
    ])

// Convert a flame reaction into a lighting gene for Sprite.Light / Sculpt3D.Light.
pub fn functor_combustion_to_light(r : Reaction) -> LightProfile pure =
    let flame_T = r.conditions.temperature_K
    LightProfile {
        blackbody_K = flame_T,
        flicker_hz = 14.0,                 // measured for turbulent diffusion flames
        flicker_amplitude = 0.12,
        falloff_inv_sq = true,
        warmth_bias = 0.35,
        palette = Std.Color.Palette.from_blackbody(flame_T),
    }

// Convert a molecule's IR resonance into an audible tone family (functor chem->audio).
pub fn functor_molecule_to_resonance_audio(m : Molecule) -> AudioResonance pure =
    AudioResonance {
        fundamental_hz = scale_ir_to_audio(m.ir_vibrational.primary_mode_cm1()),
        overtones = m.ir_vibrational.map(scale_ir_to_audio),
        timbre = "bell",
        decay_s = 4.5,
    }

fn scale_ir_to_audio(cm1 : Scalar) -> Scalar pure =
    // Linear map from vibrational wavenumber (cm^-1) to audible Hz
    // so that 500 cm^-1 -> 110 Hz (A2) and 4000 cm^-1 -> 880 Hz (A5).
    110.0 + (cm1 - 500.0) * (770.0 / 3500.0)

// Convert a rust reaction into a material-aging field for the Material engine.
pub fn functor_corrosion_to_aging_field(r : Reaction, age_years : Scalar) -> Field pure =
    Field.time_integrated(
        rate = r.arrhenius_a * exp(- r.activation_kj * 1000.0 / (GAS_R * r.conditions.temperature_K)),
        age_seconds = age_years * 31_557_600.0,
        spatial_profile = "surface_exponential",
    )

// Convert a photosynthesis reaction into a plant-growth temporal gene.
pub fn functor_photosynthesis_to_growth(r : Reaction, par_mean : Scalar) -> Temporal pure =
    Temporal.logistic(
        k = 0.08 * (par_mean / r.conditions.temperature_K),
        carrying_capacity = 1.0,
        inflection_day = 21.0,
    )

