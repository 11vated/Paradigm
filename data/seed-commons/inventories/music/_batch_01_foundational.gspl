// 09. Water-molecule sonification — IR spectrum → audio via chem functor
pub fn water_molecule_sonification() -> Std.Music.Seed pure =
    let water = Chem.water()
    seed Std.Music.Seed {
        name = "music.water_molecule_sonification", version = "1.0.0",
        kind = Std.Music.Kind.Sonification,
        source_kind = "molecule",
        source_ref = "chem://molecule/water@v1",
        functor_ref = "chem://functor/molecule_to_resonance_audio@v1",
        ir_peaks_cm_inv = [1595.0, 3657.0, 3756.0],
        mapped_fundamental_hz = 350.9,
        duration_ms = 4000.0,
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.72, c = 0.08, h = 220.0 },
            Std.Color.OKLCh { l = 0.88, c = 0.06, h = 215.0 },
            Std.Color.OKLCh { l = 0.96, c = 0.02, h = 210.0 },
        ]),
        lineage = Lineage.from_parents([
            "chem://molecule/water@v1",
            "seed_commons.libraries.chemistry@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

