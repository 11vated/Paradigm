// seed-commons/inventories/music/_batch_01_foundational.gspl
//
// Music inventory — batch 01 of the Brief 088A canonical armory.
// Ten foundational music seeds. This is the first batch to aggressively
// exercise the kernel resonance gene type (spec/02 gene #15) via
// fundamental-frequency, harmonic-stack, and envelope fields. A12 equal
// temperament with A4 = 440 Hz reference is declared up front.
//
// Cross-category functor entries consume the functor_molecule_to_resonance_audio
// bridge from seed_commons.libraries.chemistry for spectrum-to-pitch mapping.
//
// License: GSPL Open Specification License
// rng_seed prefix: "seed_commons.inventories.music"

module seed_commons.inventories.music.batch01

import Std.Color
import Std.Math
import Std.Music
import Std.Resonance
import seed_commons.libraries.chemistry as Chem

// Reference tuning (A4 = 440 Hz, 12-TET)
const A4_HZ: f64 = 440.0
const OCTAVE_RATIO: f64 = 2.0
const SEMITONE_RATIO: f64 = 1.059_463_094_359_295

// 01. Middle C piano note — equal temperament C4
pub fn piano_middle_c() -> Std.Music.Seed pure =
    seed Std.Music.Seed {
        name = "music.piano_middle_c", version = "1.0.0",
        kind = Std.Music.Kind.Note,
        instrument = "grand_piano",
        fundamental_hz = 261.625_565_3,
        harmonics = Std.Resonance.HarmonicStack {
            partials = [
                (1.0, 1.000),
                (2.0, 0.620),
                (3.0, 0.410),
                (4.0, 0.250),
                (5.0, 0.150),
                (6.0, 0.080),
            ],
            inharmonicity_coef = 4.0e-4,
        },
        envelope = Std.Music.Envelope.ADSR {
            attack_ms = 8.0,
            decay_ms = 180.0,
            sustain_level = 0.35,
            release_ms = 1200.0,
        },
        duration_ms = 2200.0,
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.22, c = 0.04, h = 260.0 },
            Std.Color.OKLCh { l = 0.62, c = 0.12, h = 240.0 },
            Std.Color.OKLCh { l = 0.92, c = 0.06, h = 220.0 },
        ]),
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

