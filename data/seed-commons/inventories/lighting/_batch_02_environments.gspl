        },
        palette = Std.Color.Palette.from_blackbody(6000.0),
        falloff = Std.Light.Falloff.InverseSquare,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 23. Forest canopy dappled — directional sun + foliage occlusion mask
pub fn forest_canopy_dappled() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.forest_canopy_dappled", version = "1.0.0",
        source = Std.Light.Source.MaskedDirectional {
            azimuth_deg = 180.0, elevation_deg = 65.0,
            blackbody_K = 5500.0, lux = 22_000.0,
            mask_kind = "perlin_canopy", mask_scale_m = 1.4, mask_density = 0.65,
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.18, c = 0.06, h = 130.0 },
            Std.Color.OKLCh { l = 0.55, c = 0.10, h = 110.0 },
            Std.Color.OKLCh { l = 0.88, c = 0.06, h = 95.0  },
        ]),
        falloff = Std.Light.Falloff.Parallel,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 24. Stained-glass window cast — wavelength-filtered directional
pub fn stained_glass_cast() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.stained_glass_cast", version = "1.0.0",
        source = Std.Light.Source.FilteredDirectional {
            azimuth_deg = 120.0, elevation_deg = 55.0,
            blackbody_K = 5500.0, lux = 18_000.0,
            transmission_spectrum_nm = [
                { nm = 450.0, t = 0.92 },
                { nm = 550.0, t = 0.10 },
                { nm = 620.0, t = 0.78 },
            ],
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.42, c = 0.20, h = 260.0 },
            Std.Color.OKLCh { l = 0.55, c = 0.22, h = 25.0  },
            Std.Color.OKLCh { l = 0.85, c = 0.10, h = 90.0  },
        ]),
        falloff = Std.Light.Falloff.Parallel,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 25. CRT monitor glow — phosphor P22 RGB triad
pub fn crt_monitor_glow() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.crt_monitor_glow", version = "1.0.0",
        source = Std.Light.Source.AreaEmission {
            bounds = Std.Light.Bounds.PlaneRect { size_m = Vector.from([0.32, 0.24]) },
            phosphor_set = "P22-RGB",
            phosphor_lines_nm = Vector.from([612.0, 543.0, 462.0]),
            luminance_cd_m2 = 220.0,
            scanline_hz = 60.0,
        },
        palette = Std.Color.Palette.from_spectrum_lines(Vector.from([612.0, 543.0, 462.0])),
        falloff = Std.Light.Falloff.InverseSquare,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

