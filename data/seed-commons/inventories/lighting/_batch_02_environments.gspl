        source = Std.Light.Source.AbsorbingVolume {
            base_color = Std.Color.OKLCh { l = 0.30, c = 0.08, h = 220.0 },
            depth_m    = 50.0,
            absorption_coeffs_nm = [
                { nm = 450.0, k = 0.015 },
                { nm = 550.0, k = 0.064 },
                { nm = 650.0, k = 0.340 },
            ],
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.08, c = 0.04, h = 230.0 },
