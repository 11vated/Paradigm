module seed_commons.inventories.lighting.batch02

import Std.Color
import Std.Math
import Std.Light
import seed_commons.libraries.chemistry as Chem

// 11. Twilight (civil) — sun 6° below horizon
pub fn twilight_civil() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.twilight_civil", version = "1.0.0",
        source = Std.Light.Source.Hemispheric {
            up_color   = Std.Color.OKLCh { l = 0.42, c = 0.10, h = 270.0 },
            down_color = Std.Color.OKLCh { l = 0.58, c = 0.18, h = 30.0  },
            lux        = 380.0,
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.30, c = 0.10, h = 280.0 },
            Std.Color.OKLCh { l = 0.55, c = 0.16, h = 20.0  },
            Std.Color.OKLCh { l = 0.78, c = 0.10, h = 50.0  },
        ]),
        falloff = Std.Light.Falloff.None,
        lineage = Lineage.from_parents(["chem://atmosphere/us-std-1976@sea-level"]),
        provenance = Provenance.HumanAuthored,
    }

// 12. Twilight (nautical) — sun 12° below horizon
pub fn twilight_nautical() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.twilight_nautical", version = "1.0.0",
        source = Std.Light.Source.Hemispheric {
            up_color   = Std.Color.OKLCh { l = 0.18, c = 0.08, h = 260.0 },
            down_color = Std.Color.OKLCh { l = 0.30, c = 0.10, h = 250.0 },
            lux        = 8.0,
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.10, c = 0.04, h = 260.0 },
            Std.Color.OKLCh { l = 0.28, c = 0.10, h = 250.0 },
            Std.Color.OKLCh { l = 0.50, c = 0.08, h = 245.0 },
        ]),
        falloff = Std.Light.Falloff.None,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 13. Sunrise (sun on horizon, Rayleigh-saturated reds)
pub fn sunrise_horizon() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.sunrise_horizon", version = "1.0.0",
        source = Std.Light.Source.Directional {
            azimuth_deg = 90.0, elevation_deg = 0.5,
            blackbody_K = 2200.0, lux = 12_000.0,
        },
        palette = Std.Color.Palette.from_blackbody(2200.0),
        falloff = Std.Light.Falloff.Parallel,
        lineage = Lineage.from_parents(["chem://atmosphere/us-std-1976@sea-level"]),
        provenance = Provenance.HumanAuthored,
    }

// 14. Stormy sky — diffuse cool with high-contrast cloud bursts
pub fn stormy_sky() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.stormy_sky", version = "1.0.0",
        source = Std.Light.Source.Hemispheric {
            up_color = Std.Color.OKLCh { l = 0.32, c = 0.02, h = 250.0 },
            down_color = Std.Color.OKLCh { l = 0.42, c = 0.02, h = 240.0 },
            lux = 4_500.0,
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.18, c = 0.02, h = 245.0 },
            Std.Color.OKLCh { l = 0.42, c = 0.02, h = 250.0 },
            Std.Color.OKLCh { l = 0.74, c = 0.02, h = 255.0 },
        ]),
        falloff = Std.Light.Falloff.None,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 15. Lightning flash — single-frame ultra-bright blackbody pulse
pub fn lightning_flash() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.lightning_flash", version = "1.0.0",
        source = Std.Light.Source.PointPulse {
            position = Vector.from([0.0, 250.0, 0.0]),
            blackbody_K = 28_000.0,
            duration_ms = 30.0,
            peak_lumens = 5.0e9,
        },
        palette = Std.Color.Palette.from_blackbody(28_000.0),
        falloff = Std.Light.Falloff.InverseSquare,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 16. Underwater (5 m depth) — water absorption attenuates red
pub fn underwater_5m() -> Std.Light.Seed pure =
    let water = Chem.water()
    seed Std.Light.Seed {
        name = "light.underwater_5m", version = "1.0.0",
        source = Std.Light.Source.AbsorbingVolume {
            base_color = Std.Color.OKLCh { l = 0.62, c = 0.10, h = 200.0 },
            depth_m    = 5.0,
            absorption_coeffs_nm = [
                { nm = 450.0, k = 0.015 },
                { nm = 550.0, k = 0.064 },
                { nm = 650.0, k = 0.340 },
            ],
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.22, c = 0.10, h = 200.0 },
            Std.Color.OKLCh { l = 0.55, c = 0.12, h = 195.0 },
            Std.Color.OKLCh { l = 0.78, c = 0.08, h = 190.0 },
        ]),
        falloff = Std.Light.Falloff.BeerLambert { coeff = 0.1 },
        lineage = Lineage.from_parents(["chem://molecule/water@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// 17. Underwater (50 m depth) — only blue survives
pub fn underwater_50m() -> Std.Light.Seed pure =
