    }

// 18. Foggy morning — Mie scattering profile
pub fn foggy_morning() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.foggy_morning", version = "1.0.0",
        source = Std.Light.Source.VolumetricScatter {
            scatter_profile = Std.Light.Scatter.Mie { asymmetry = 0.85 },
            extinction_per_m = 0.012,
            ambient_color = Std.Color.OKLCh { l = 0.82, c = 0.02, h = 80.0 },
            lux = 6_000.0,
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.62, c = 0.02, h = 85.0 },
            Std.Color.OKLCh { l = 0.80, c = 0.02, h = 80.0 },
            Std.Color.OKLCh { l = 0.94, c = 0.01, h = 75.0 },
        ]),
        falloff = Std.Light.Falloff.None,
        lineage = Lineage.from_parents(["chem://atmosphere/us-std-1976@sea-level"]),
        provenance = Provenance.HumanAuthored,
    }

// 19. Snowy daylight — high-albedo white-out
pub fn snowy_daylight() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.snowy_daylight", version = "1.0.0",
        source = Std.Light.Source.Hemispheric {
            up_color = Std.Color.OKLCh { l = 0.95, c = 0.02, h = 220.0 },
            down_color = Std.Color.OKLCh { l = 0.97, c = 0.01, h = 220.0 },
            lux = 25_000.0,
        },
        palette = Std.Color.Palette.D65(),
        falloff = Std.Light.Falloff.None,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 20. Aurora borealis — atomic oxygen 558 nm + nitrogen 428 nm
pub fn aurora_borealis() -> Std.Light.Seed pure =
    let oxygen = Chem.oxygen()
    seed Std.Light.Seed {
        name = "light.aurora_borealis", version = "1.0.0",
        source = Std.Light.Source.LineEmission {
            position = Vector.from([0.0, 100_000.0, 0.0]),
            lines_nm = Vector.from([557.7, 630.0, 427.8, 391.4]),
            peak_cd  = 12.0,
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.42, c = 0.18, h = 145.0 },
            Std.Color.OKLCh { l = 0.62, c = 0.20, h = 150.0 },
            Std.Color.OKLCh { l = 0.32, c = 0.16, h = 280.0 },
        ]),
        falloff = Std.Light.Falloff.None,
        lineage = Lineage.from_parents(["chem://element/oxygen@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// 21. Magnesium flare — 5400 K white incendiary
pub fn magnesium_flare() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.magnesium_flare", version = "1.0.0",
        source = Std.Light.Source.PointFlicker {
            position = Vector.from([0.0, 1.0, 0.0]),
            blackbody_K = 5400.0,
            flicker_hz  = 8.0,
            amplitude   = 0.05,
        },
        palette = Std.Color.Palette.from_blackbody(5400.0),
        falloff = Std.Light.Falloff.InverseSquare,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// 22. Welding arc — extremely bright UV-rich plasma
pub fn welding_arc() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name = "light.welding_arc", version = "1.0.0",
        source = Std.Light.Source.PointFlicker {
            position = Vector.from([0.0, 0.6, 0.0]),
            blackbody_K = 6000.0,
            flicker_hz = 60.0,
            amplitude  = 0.30,
