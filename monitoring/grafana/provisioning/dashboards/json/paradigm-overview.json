{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Server Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "process_uptime_seconds", "legendFormat": "uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Memory Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Total Seeds",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "paradigm_seeds_total", "legendFormat": "seeds" }]
    },
    {
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "paradigm_ws_active_connections", "legendFormat": "ws" }]
    },
    {
      "title": "Kernel Config",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "paradigm_kernel_engines", "legendFormat": "engines" },
        { "expr": "paradigm_kernel_gene_types", "legendFormat": "gene types" }
      ]
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "{{method}} {{route}} {{status}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Request Duration (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_ms_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_ms_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Seed Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(paradigm_seeds_created_total[5m])", "legendFormat": "created" },
        { "expr": "rate(paradigm_seeds_mutated_total[5m])", "legendFormat": "mutated" },
        { "expr": "rate(paradigm_seeds_bred_total[5m])", "legendFormat": "bred" },
        { "expr": "rate(paradigm_seeds_evolved_total[5m])", "legendFormat": "evolved" },
        { "expr": "rate(paradigm_seeds_composed_total[5m])", "legendFormat": "composed" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Agent & Auth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "rate(paradigm_agent_queries_total[5m])", "legendFormat": "agent queries" },
        { "expr": "rate(paradigm_auth_attempts_total[5m])", "legendFormat": "auth attempts" },
        { "expr": "rate(paradigm_auth_successes_total[5m])", "legendFormat": "auth successes" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["paradigm"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Paradigm Engine Overview",
  "uid": "paradigm-overview",
  "version": 1
}
