            Std.Color.OKLCh { l = 0.80, c = 0.03, h = 82.0 },
            Std.Color.OKLCh { l = 0.90, c = 0.02, h = 80.0 },
        ]),
        gloss = 0.12,
        roughness = 0.78,
        sheen_anisotropy = 0.35,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// -----------------------------------------------------------------------------
// 07. Wet clay — earthenware, slip-glazed
// -----------------------------------------------------------------------------
pub fn wet_clay() -> Std.Material.Seed pure =
    seed Std.Material.Seed {
        name = "material.wet_clay", version = "1.0.0",
        kind = Std.Material.Kind.Ceramic,
        composition = "kaolinite + quartz + feldspar",
        water_fraction = 0.22,
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.32, c = 0.08, h = 55.0 },
            Std.Color.OKLCh { l = 0.52, c = 0.10, h = 50.0 },
            Std.Color.OKLCh { l = 0.68, c = 0.08, h = 45.0 },
        ]),
        gloss = 0.55,          // wet sheen
        roughness = 0.48,
        subsurface_depth_mm = 0.4,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// -----------------------------------------------------------------------------
// 08. Crystal glass (SiO2 + PbO lead crystal)
// -----------------------------------------------------------------------------
pub fn crystal_glass() -> Std.Material.Seed pure =
    seed Std.Material.Seed {
        name = "material.crystal_glass", version = "1.0.0",
        kind = Std.Material.Kind.Glass,
        chemical_formula = "SiO2 + 24% PbO",
        refractive_index = 1.545,
        abbe_number      = 58.0,
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.96, c = 0.01, h = 220.0 },
            Std.Color.OKLCh { l = 0.88, c = 0.02, h = 215.0 },
            Std.Color.OKLCh { l = 0.75, c = 0.03, h = 210.0 },
        ]),
        gloss = 0.98,
        roughness = 0.02,
        transmission = 0.92,
        lineage = Lineage.from_parents([]),
        provenance = Provenance.HumanAuthored,
    }

// -----------------------------------------------------------------------------
// 09. Rusting iron (120-year aged) — chem functor driven
// -----------------------------------------------------------------------------
pub fn rusting_iron_120y() -> Std.Material.Seed pure =
    let aging = Chem.functor_corrosion_to_aging_field(Chem.rust_iron(), 120.0)
    seed Std.Material.Seed {
        name = "material.rusting_iron_120y", version = "1.0.0",
        kind = Std.Material.Kind.OxidizedMetal,
        base_element = "Fe",
        aging_field  = aging,
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.22, c = 0.08, h = 40.0 },
            Std.Color.OKLCh { l = 0.45, c = 0.16, h = 35.0 },
            Std.Color.OKLCh { l = 0.58, c = 0.14, h = 55.0 },
            Std.Color.OKLCh { l = 0.32, c = 0.05, h = 25.0 },
        ]),
        gloss = 0.18,
        roughness = 0.72,
        lineage = Lineage.from_parents([
            "chem://reaction/oxidation-iron-aqueous@v1",
            "chem://element/iron@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

// -----------------------------------------------------------------------------
// 10. Ultramarine oil paint (pigment + linseed oil vehicle)
// -----------------------------------------------------------------------------
pub fn ultramarine_oil_paint() -> Std.Material.Seed pure =
    let pigment = Chem.ultramarine_blue()
    let palette = Chem.functor_pigment_to_palette(pigment)
    seed Std.Material.Seed {
        name = "material.ultramarine_oil_paint", version = "1.0.0",
        kind = Std.Material.Kind.OilPaint,
        pigment_ref = "chem://pigment/ultramarine-blue@v1",
        vehicle     = "linseed_oil",
        palette     = palette,
        gloss       = 0.52,
        roughness   = 0.38,
        opacity     = pigment.opacity,
        lightfastness = pigment.lightfastness,
        lineage = Lineage.from_parents(["chem://pigment/ultramarine-blue@v1"]),
        provenance = Provenance.HumanAuthored,
    }

