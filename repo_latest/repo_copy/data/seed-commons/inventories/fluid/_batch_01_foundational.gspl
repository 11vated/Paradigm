// rng_seed prefix: "seed_commons.inventories.fluid"

module seed_commons.inventories.fluid.batch01

import Std.Color
import Std.Fluid
import Std.Math
import seed_commons.libraries.chemistry as Chem

// 01. Fresh water — standard incompressible liquid
pub fn fresh_water() -> Std.Fluid.Seed pure =
    let water = Chem.water()
    seed Std.Fluid.Seed {
        name = "fluid.fresh_water", version = "1.0.0",
        substance = water,
        density_kg_m3 = 998.2,
        viscosity_Pa_s = 1.002e-3,
        surface_tension_N_m = 0.0728,
        refractive_index = 1.333,
        temperature_K = 293.15,
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.72, c = 0.04, h = 220.0 },
            Std.Color.OKLCh { l = 0.88, c = 0.03, h = 215.0 },
            Std.Color.OKLCh { l = 0.96, c = 0.02, h = 210.0 },
        ]),
        lineage = Lineage.from_parents(["chem://molecule/water@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// 02. Seawater — 35 g/kg salinity
pub fn seawater_standard() -> Std.Fluid.Seed pure =
    let water = Chem.water()
    seed Std.Fluid.Seed {
        name = "fluid.seawater_standard", version = "1.0.0",
        substance = water,
        salinity_g_kg = 35.0,
        density_kg_m3 = 1025.0,
        viscosity_Pa_s = 1.08e-3,
        surface_tension_N_m = 0.0740,
        refractive_index = 1.339,
        temperature_K = 288.15,
        absorption_coeff_1_m = Std.Math.spectrum_from_pairs([
            (450.0, 0.015),
            (550.0, 0.064),
            (650.0, 0.340),
