// seed-commons/inventories/fluid/_batch_01_foundational.gspl
//
// Fluid inventory — batch 01 of the Brief 088A canonical armory.
// Ten foundational fluid seeds covering water, oil, blood, lava, mercury,
// honey, milk, wine, seawater, and liquid nitrogen. Substance primitives
// draw from seed_commons.libraries.chemistry where applicable.
//
