pub fn profile_to_balance_curve_functor() -> Functor pure =
    Functor.id("power://functor/profile_to_balance_curve@v1")

pub fn move_to_animation_timing_functor() -> Functor pure =
    Functor.id("power://functor/move_to_animation_timing@v1")

pub fn transformation_to_vfx_bundle_functor() -> Functor pure =
    Functor.id("power://functor/transformation_to_vfx_bundle@v1")

