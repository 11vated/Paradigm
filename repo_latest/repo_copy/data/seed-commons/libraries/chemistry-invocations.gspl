// =============================================================================
// 06. Yellow-ochre cave-painting wall (Upper Paleolithic)
// =============================================================================
pub fn ochre_cave_wall() -> Std.Material.Seed pure =
    let pigment = Chem.yellow_ochre()
    let palette = Chem.functor_pigment_to_palette(pigment)
