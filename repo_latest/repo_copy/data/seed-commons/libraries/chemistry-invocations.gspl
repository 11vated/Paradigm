        lights      = [forge_flame(), sodium_street_lamp()],
        particles   = [campfire_smoke()],
        fluids      = [],
        materials   = [rusting_iron_sword(), ultramarine_wall()],
        atmosphere  = sea_level_haze(),
        lineage = Lineage.from_parents([
            "examples.chemistry.forge_flame@v1",
            "examples.chemistry.campfire_smoke@v1",
            "examples.chemistry.rusting_iron_sword@v1",
            "examples.chemistry.ultramarine_wall@v1",
            "examples.chemistry.sea_level_haze@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

