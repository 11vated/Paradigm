        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 18. Sacred grove scene (photosynthesis + oak + water + meditation bell)
// =============================================================================
pub fn sacred_grove_scene() -> Std.Scene.Seed pure =
    seed Std.Scene.Seed {
        name    = "chem.sacred_grove",
        version = "1.0.0",
        lights      = [],
        particles   = [],
        fluids      = [freshwater_stream()],
        plants      = [photosynthesising_oak_sapling()],
        audio       = [water_resonance_bell()],
        atmosphere  = sea_level_haze(),
        lineage = Lineage.from_parents([
            "examples.chemistry.photosynthesising_oak_sapling@v1",
            "examples.chemistry.freshwater_stream@v1",
            "examples.chemistry.water_resonance_bell@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 19. Cross-domain functor seed: iron element -> pixel-art portrait palette
// =============================================================================
pub fn iron_element_portrait_palette() -> Std.Sprite.Palette pure =
    let iron = Chem.iron()
    Std.Cross.element_to_portrait_palette(
        element = iron,
        lineage_parent = "chem://element/iron@v1",
        rng_seed = "chem.iron_portrait:v1",
    )

// =============================================================================
// 20. Quantum-superposed pigment seed (quantum gene demonstration)
// =============================================================================
// Demonstrates that chemistry composes into the kernel's quantum gene: a single
// seed whose color collapses to ultramarine, vermilion, or ochre at grow time,
// seeded by the downstream consumer's rng. Useful for procedural art where
// pigment choice is a stylistic roll.
pub fn quantum_pigment_wash() -> Std.Material.Seed pure =
    let quantum_state = Std.Quantum.superposition([
        (Chem.ultramarine_blue(), 0.35),
        (Chem.vermilion(),        0.35),
        (Chem.yellow_ochre(),     0.30),
    ])
    let collapsed = Std.Quantum.collapse(quantum_state, observer = "grow_rng")
    let palette   = Chem.functor_pigment_to_palette(collapsed)
    seed Std.Material.Seed {
        name    = "chem.quantum_pigment_wash",
        version = "1.0.0",
        kind    = Std.Material.Kind.Wash,
        palette = palette,
        gloss   = 0.18,
        roughness = 0.55,
        opacity = collapsed.opacity,
        lineage = Lineage.from_parents([
            "chem://pigment/ultramarine-blue@v1",
            "chem://pigment/vermilion@v1",
            "chem://pigment/yellow-ochre@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

