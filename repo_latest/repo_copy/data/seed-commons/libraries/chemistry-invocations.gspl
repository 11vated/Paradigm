// seed-commons/libraries/chemistry-invocations.gspl
//
// Twenty canonical example invocations of `seed_commons.libraries.chemistry`.
// Each invocation is a complete, runnable GSPL seed that depends ONLY on
// `Std.*` and `seed_commons.libraries.chemistry`. No other commons module is
// required. Every seed is pure, deterministic, and signable.
//
// These twenty examples collectively prove out every functor exported from
// chemistry.gspl. They are the first downstream consumers of the library and
// serve as the regression surface for any future edit to chemistry.gspl.
//
// License: GSPL Open Specification License
// rng_seed base: "seed_commons.examples.chemistry:<seed_name>:v1"
// lineage parent: seed_commons.libraries.chemistry@v1

module seed_commons.examples.chemistry

import Std.Color
import Std.Math
import Std.Time
import Std.Units
import Std.Sprite
import Std.Sculpt3D
import Std.Particle
import Std.Material
import Std.Light
import Std.Audio
import Std.Plant
import Std.Fluid
import Std.Weather
import Std.Scene
import Std.Cross
import seed_commons.libraries.chemistry as Chem

// =============================================================================
// 01. Candle flame (methane combustion -> light profile)
// =============================================================================
pub fn candle_flame() -> Std.Light.Seed pure =
    let combustion = Chem.combust_methane()
    let profile    = Chem.functor_combustion_to_light(combustion)
    seed Std.Light.Seed {
        name    = "chem.candle_flame",
        version = "1.0.0",
        source  = Std.Light.Source.PointFlicker {
            position    = Vector.from([0.0, 0.0, 0.0]),
            blackbody_K = profile.blackbody_K * 0.72,   // candles sit cooler than adiabatic
            flicker_hz  = profile.flicker_hz,
            amplitude   = profile.flicker_amplitude,
        },
        palette    = profile.palette,
        falloff    = Std.Light.Falloff.InverseSquare,
        lineage    = Lineage.from_parents(["chem://reaction/combustion-methane@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 02. Forge flame (methane + high O2, hotter adiabatic)
// =============================================================================
pub fn forge_flame() -> Std.Light.Seed pure =
    let combustion = Chem.combust_methane()
    let profile    = Chem.functor_combustion_to_light(combustion)
    seed Std.Light.Seed {
        name    = "chem.forge_flame",
        version = "1.0.0",
        source  = Std.Light.Source.PointFlicker {
            position    = Vector.from([0.0, 0.3, 0.0]),
            blackbody_K = profile.blackbody_K,             // full adiabatic
            flicker_hz  = 22.0,                             // forced-air draft
            amplitude   = 0.18,
        },
        palette    = Std.Color.Palette.from_blackbody(profile.blackbody_K),
        falloff    = Std.Light.Falloff.InverseSquare,
        lineage    = Lineage.from_parents(["chem://reaction/combustion-methane@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 03. Sodium street lamp (Na emission doublet)
// =============================================================================
pub fn sodium_street_lamp() -> Std.Light.Seed pure =
    let sodium = Chem.sodium()
    seed Std.Light.Seed {
        name    = "chem.sodium_lamp",
        version = "1.0.0",
        source  = Std.Light.Source.LineEmission {
            position  = Vector.from([0.0, 4.5, 0.0]),
            lines_nm  = sodium.emission_lines_nm,
            peak_cd   = 15_000.0,
        },
        palette    = Std.Color.Palette.from_spectrum_lines(sodium.emission_lines_nm),
        falloff    = Std.Light.Falloff.InverseSquare,
        lineage    = Lineage.from_parents(["chem://element/sodium@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 04. Ultramarine-blue painted wall (pigment -> material palette)
// =============================================================================
pub fn ultramarine_wall() -> Std.Material.Seed pure =
    let pigment = Chem.ultramarine_blue()
    let palette = Chem.functor_pigment_to_palette(pigment)
    seed Std.Material.Seed {
        name    = "chem.ultramarine_wall",
        version = "1.0.0",
        kind    = Std.Material.Kind.PaintedPlaster,
        palette = palette,
        gloss   = 0.08,
        roughness = 0.78,
        opacity = pigment.opacity,
        lightfastness = pigment.lightfastness,
        lineage = Lineage.from_parents(["chem://pigment/ultramarine-blue@v1"]),
        provenance = Provenance.HumanAuthored,
    }

