        particles   = [champagne_bubbles()],
        fluids      = [freshwater_stream()],
        materials   = [ochre_cave_wall()],
        atmosphere  = sea_level_haze(),
        lineage = Lineage.from_parents([
            "examples.chemistry.firefly_glow@v1",
            "examples.chemistry.champagne_bubbles@v1",
            "examples.chemistry.freshwater_stream@v1",
            "examples.chemistry.ochre_cave_wall@v1",
            "examples.chemistry.sea_level_haze@v1",
