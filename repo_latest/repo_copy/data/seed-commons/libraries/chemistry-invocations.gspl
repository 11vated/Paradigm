// =============================================================================
// 07. Rusting iron sword (Arrhenius aging field over 120 years)
// =============================================================================
pub fn rusting_iron_sword() -> Std.Material.Seed pure =
    let rust_rxn = Chem.rust_iron()
    let aging    = Chem.functor_corrosion_to_aging_field(rust_rxn, 120.0)
    seed Std.Material.Seed {
        name    = "chem.rusting_iron_sword",
        version = "1.0.0",
        kind    = Std.Material.Kind.OxidizedMetal,
        base_element = "Fe",
        aging_field  = aging,
        gloss        = 0.22,
        roughness    = 0.66,
        palette      = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.22, c = 0.08, h = 40.0 },
            Std.Color.OKLCh { l = 0.45, c = 0.16, h = 35.0 },
            Std.Color.OKLCh { l = 0.58, c = 0.14, h = 55.0 },
            Std.Color.OKLCh { l = 0.32, c = 0.05, h = 25.0 },
        ]),
        lineage = Lineage.from_parents([
            "chem://reaction/oxidation-iron-aqueous@v1",
            "chem://element/iron@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 08. Champagne bubbles (CO2 solubility and nucleation)
// =============================================================================
pub fn champagne_bubbles() -> Std.Particle.Seed pure =
    let co2   = Chem.carbon_dioxide()
    let water = Chem.water()
    seed Std.Particle.Seed {
        name    = "chem.champagne_bubbles",
        version = "1.0.0",
        kind    = Std.Particle.Kind.GasInLiquid,
        solute_molecule   = co2,
        solvent_molecule  = water,
        nucleation_rate   = 80.0,                      // sites / cm^2 / s
        mean_radius_m     = 0.00035,                   // 0.35 mm
        radius_variance   = 0.6,
        rise_velocity_mps = 0.08,
        count_per_second  = 250.0,
        lineage = Lineage.from_parents([
            "chem://molecule/carbon-dioxide@v1",
            "chem://molecule/water@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 09. Campfire smoke (incomplete combustion + soot particle field)
// =============================================================================
pub fn campfire_smoke() -> Std.Particle.Seed pure =
    let combustion = Chem.combust_methane()
    seed Std.Particle.Seed {
        name    = "chem.campfire_smoke",
        version = "1.0.0",
        kind    = Std.Particle.Kind.Aerosol,
        source_reaction = combustion,
        soot_fraction   = 0.08,                        // rich mixture
        mean_radius_m   = 1.2e-7,                      // 120 nm
        density_kg_m3   = 1_800.0,
        emission_rate   = 0.45,                        // kg/s
        color           = Std.Color.OKLCh { l = 0.28, c = 0.01, h = 60.0 },
        buoyancy        = 1.1,
        lineage = Lineage.from_parents(["chem://reaction/combustion-methane@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 10. Fresh-water stream (real water properties -> fluid seed)
// =============================================================================
pub fn freshwater_stream() -> Std.Fluid.Seed pure =
    let water = Chem.water()
    seed Std.Fluid.Seed {
        name    = "chem.freshwater_stream",
        version = "1.0.0",
        molecule        = water,
        density_kg_m3   = 997.0,
        viscosity_pa_s  = 0.00089,
        surface_tension_n_m = 0.0728,
        refractive_index = 1.333,
        absorption_nm    = water.uv_vis_nm,
        appearance_color = water.appearance_color,
        flow_profile     = Std.Fluid.Profile.LaminarShallow { depth_m = 0.12, velocity_mps = 0.35 },
        lineage = Lineage.from_parents(["chem://molecule/water@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 11. Sea-level atmospheric haze (HITRAN absorption -> scene atmosphere)
// =============================================================================
pub fn sea_level_haze() -> Std.Scene.Atmosphere pure =
    let atmo = Chem.sea_level_atmosphere()
    seed Std.Scene.Atmosphere {
        name    = "chem.sea_level_haze",
        version = "1.0.0",
        pressure_pa   = atmo.pressure_pa,
        temperature_K = atmo.temperature_K,
        composition   = atmo.composition,
        scatter_profile = Std.Scene.Scatter.Rayleigh { beta_550nm = 1.15e-5 },
        absorption_field = atmo.hitran_profile,
        visibility_m     = 18_000.0,
        lineage = Lineage.from_parents(["chem://atmosphere/us-std-1976@sea-level"]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 12. Firefly bioluminescence (fluorophore-like spectrum) — light sprite
// =============================================================================
pub fn firefly_glow() -> Std.Light.Seed pure =
    seed Std.Light.Seed {
        name    = "chem.firefly_glow",
        version = "1.0.0",
        source  = Std.Light.Source.PointPulse {
            position      = Vector.from([0.0, 1.0, 0.0]),
            emission_nm   = 560.0,                      // luciferin/luciferase peak
            quantum_yield = 0.41,
            period_ms     = 750.0,
            duty_cycle    = 0.15,
        },
        palette = Std.Color.Palette.from_oklch([
            Std.Color.OKLCh { l = 0.88, c = 0.18, h = 125.0 },
            Std.Color.OKLCh { l = 0.70, c = 0.14, h = 120.0 },
            Std.Color.OKLCh { l = 0.40, c = 0.08, h = 115.0 },
        ]),
        falloff    = Std.Light.Falloff.InverseSquare,
        lineage    = Lineage.from_parents(["chem://molecule/luciferin@v1"]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 13. Photosynthesising oak sapling (functor chem->plant temporal)
// =============================================================================
pub fn photosynthesising_oak_sapling() -> Std.Plant.Seed pure =
    let photo  = Chem.photosynthesis()
    let growth = Chem.functor_photosynthesis_to_growth(photo, par_mean = 900.0)
    seed Std.Plant.Seed {
        name    = "chem.oak_sapling",
        version = "1.0.0",
        species          = "Quercus robur",
        height_m         = 0.6,
        leaf_pigment     = Chem.yellow_ochre(),         // placeholder chlorophyll analog
        growth_curve     = growth,
        metabolic_source = photo,
        lineage = Lineage.from_parents([
            "chem://reaction/photosynthesis@v1",
            "chem://molecule/glucose@v1",
        ]),
        provenance = Provenance.HumanAuthored,
    }

// =============================================================================
// 14. Water IR resonance -> meditation bell (functor chem->audio)
// =============================================================================
pub fn water_resonance_bell() -> Std.Audio.Seed pure =
    let water = Chem.water()
    let res   = Chem.functor_molecule_to_resonance_audio(water)
    seed Std.Audio.Seed {
        name    = "chem.water_bell",
        version = "1.0.0",
        kind    = Std.Audio.Kind.Bell,
        fundamental_hz = res.fundamental_hz,
        overtones      = res.overtones,
        decay_s        = res.decay_s,
        timbre         = res.timbre,
        lineage        = Lineage.from_parents(["chem://molecule/water@v1"]),
        provenance     = Provenance.HumanAuthored,
    }

// =============================================================================
// 15. CO2 IR resonance -> deep drone pad
// =============================================================================
pub fn co2_drone_pad() -> Std.Audio.Seed pure =
    let co2 = Chem.carbon_dioxide()
    let res = Chem.functor_molecule_to_resonance_audio(co2)
    seed Std.Audio.Seed {
        name    = "chem.co2_drone",
        version = "1.0.0",
        kind    = Std.Audio.Kind.Drone,
        fundamental_hz = res.fundamental_hz * 0.5,     // drop an octave for pad feel
        overtones      = res.overtones,
        decay_s        = 12.0,
        timbre         = "pad",
        lineage        = Lineage.from_parents(["chem://molecule/carbon-dioxide@v1"]),
        provenance     = Provenance.HumanAuthored,
    }

