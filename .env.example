# ─── Paradigm Absolute — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=INFO

# Authentication (generate with: openssl rand -hex 32)
JWT_SECRET=generate-a-random-64-char-hex-string-here

# CORS (comma-separated origins; defaults to localhost:3000,5173)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (for Docker Compose)
MONGO_URI=mongodb://mongo:27017/paradigm

# Cache
REDIS_URL=redis://redis:6379

# Optional: Gemini API (for embedding generation only — NOT required for core ops)
GEMINI_API_KEY=
APP_URL=http://localhost:3000

# Docker Compose overrides
APP_PORT=3000
NGINX_PORT=80

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=paradigm

# Optional: LLM Inference (fine-tuned Llama 3 for enhanced agent responses)
# Leave blank to use deterministic-only agent
LLM_INFERENCE_URL=
# LLM_INFERENCE_URL=http://llm-inference:8001

# Optional: On-chain minting
SEPOLIA_RPC_URL=
